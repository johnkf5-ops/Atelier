# Atelier env variables — copy to .env.local and fill in.
# Vercel Production + Preview + Development env vars should mirror this
# EXCEPT for ATELIER_IS_RESETTABLE_DB which MUST ONLY exist locally.

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Turso (LibSQL) ---
TURSO_DATABASE_URL=libsql://atelier-<org>.turso.io
TURSO_AUTH_TOKEN=...

# --- Vercel Blob ---
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# --- Managed Agents (written by `pnpm setup:agents`) ---
ATELIER_ENV_ID=env_...
SCOUT_AGENT_ID=agent_...
RUBRIC_AGENT_ID=agent_...

# --- Destructive-reset guardrail ---
# Set to "true" ONLY in local .env.local. NEVER set in Vercel Production.
# Without this, scripts/reset-db.ts refuses to drop tables.
# ATELIER_IS_RESETTABLE_DB=true
